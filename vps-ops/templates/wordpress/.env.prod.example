# Copia in .env e compila. NON committare il .env.
# PROJECT_NAME prefissa container/volumi/rete: deve essere univoco sulla VPS.

PROJECT_NAME=mariorossi

# Database (le password vanno generate: openssl rand -base64 24)
MYSQL_DATABASE=mariorossi
MYSQL_USER=mariorossi
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Dominio pubblico (informativo; WP_HOME/WP_SITEURL si impostano nel DB WordPress)
# SITE_DOMAIN=mariorossi.it
